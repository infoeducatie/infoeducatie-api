<% input_id = "#{form.dom_id(field)}_input" %>
<% editor_id = "#{form.dom_id(field)}_editor" %>

<div class="ie-rich-text-editor" data-rich-text-editor>
  <%= form.hidden_field field.method_name,
                        id: input_id,
                        value: field.form_value %>
  <trix-editor id="<%= editor_id %>"
               input="<%= input_id %>"
               class="trix-content ie-rich-text-editor__input"
               data-rich-text-input
               data-upload-url="<%= main_app.admin_editor_images_path %>"></trix-editor>
  <p class="ie-rich-text-editor__status"
     data-rich-text-status
     role="status"
     aria-live="polite"></p>
</div>
