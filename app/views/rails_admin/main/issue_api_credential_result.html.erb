<section class="ie-api-key-panel ie-api-key-panel--result">
  <div class="alert alert-success" role="status">
    <strong>API key created.</strong>
    Store it in the consuming service's secret manager before leaving this page.
  </div>

  <div class="ie-api-key-secret">
    <div class="ie-api-key-secret__heading">
      <div>
        <h4><%= @api_credential.name %></h4>
        <p>This secret is shown once. InfoEducatie stores only its digest.</p>
      </div>
      <span class="label label-warning">One-time secret</span>
    </div>

    <label for="issued-api-token">API key</label>
    <div class="input-group">
      <input id="issued-api-token"
             class="form-control ie-api-key-secret__value"
             type="text"
             value="<%= @plaintext_token %>"
             readonly
             spellcheck="false"
             autocomplete="off"
             data-api-token>
      <span class="input-group-btn">
        <button class="btn btn-default"
                type="button"
                data-copy-api-token
                aria-describedby="api-token-copy-status">
          <i class="fas fa-copy" aria-hidden="true"></i>
          Copy
        </button>
      </span>
    </div>
    <p id="api-token-copy-status"
       class="ie-api-key-secret__status"
       aria-live="polite"
       data-api-token-copy-status></p>
  </div>

  <dl class="ie-api-key-summary">
    <dt>Expires</dt>
    <dd><%= l @api_credential.expires_at, format: :long %></dd>
    <dt>Scopes</dt>
    <dd><%= @api_credential.scope_names %></dd>
  </dl>

  <div class="form-actions">
    <%= link_to "I have stored the key", index_path, class: "btn btn-primary" %>
  </div>
</section>
