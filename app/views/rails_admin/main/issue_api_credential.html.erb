<section class="ie-api-key-panel">
  <header class="ie-api-key-panel__header">
    <div>
      <h4>Issue a new API key</h4>
      <p>
        Create a service credential with only the access it needs. The secret is
        shown once and cannot be recovered later.
      </p>
    </div>
  </header>

  <% if @api_credential.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <strong>The API key could not be created.</strong>
      <ul>
        <% @api_credential.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: request.path,
                method: :post,
                scope: :api_credential,
                local: true,
                data: { turbo: false },
                html: { autocomplete: "off", class: "ie-api-key-form" } do |form| %>
    <div class="form-group">
      <%= form.label :name, "Name" %>
      <%= form.text_field :name,
                          value: @api_credential.name,
                          required: true,
                          maxlength: 120,
                          class: "form-control",
                          placeholder: "Example: Results dashboard" %>
      <p class="help-block">Use a name that identifies the consuming system.</p>
    </div>

    <div class="form-group">
      <%= form.label :description, "Purpose or owner" %>
      <%= form.text_area :description,
                         value: @api_credential.description,
                         maxlength: 1_000,
                         rows: 3,
                         class: "form-control",
                         placeholder: "Who owns this integration and what is it used for?" %>
    </div>

    <fieldset class="ie-api-key-scopes">
      <legend>Access scopes</legend>
      <%= hidden_field_tag "api_credential[scopes][]", "" %>

      <% @available_scopes.each do |scope, description| %>
        <label class="ie-api-key-scope">
          <%= check_box_tag "api_credential[scopes][]",
                            scope,
                            @api_credential.scopes.include?(scope) %>
          <span>
            <code><%= scope %></code>
            <small><%= description %></small>
          </span>
        </label>
      <% end %>

      <p class="help-block">
        Sensitive personal data requires both the dataset scope and the explicit
        personal-data scope.
      </p>
    </fieldset>

    <div class="form-group ie-api-key-form__expiry">
      <%= form.label :expires_at, "Expires at" %>
      <%= form.datetime_local_field :expires_at,
                                    value: @api_credential.expires_at&.in_time_zone&.strftime("%Y-%m-%dT%H:%M"),
                                    min: 5.minutes.from_now.strftime("%Y-%m-%dT%H:%M"),
                                    max: 1.year.from_now.strftime("%Y-%m-%dT%H:%M"),
                                    required: true,
                                    class: "form-control" %>
      <p class="help-block">
        Keys must expire within one year. Issue a replacement before this date,
        then revoke the old key.
      </p>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary" data-disable-with="Issuing key...">
        <i class="fas fa-key" aria-hidden="true"></i>
        Issue API key
      </button>
      <%= link_to "Cancel", index_path, class: "btn btn-default" %>
    </div>
  <% end %>
</section>
